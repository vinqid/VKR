digraph model_graph {
  // Dotfile by Django-Extensions graph_models
  // Created: 2026-04-21 13:19
  // Cli Options: users medics patients questionnaires appointments -g -X AbstractUser,AbstractBaseUser,PermissionsMixin,Group,Permission -o class_diagramm.dot

  fontname = "Roboto"
  fontsize = 8
  splines  = true
  rankdir = "TB"
  

  node [
    fontname = "Roboto"
    fontsize = 8
    shape = "plaintext"
  ]

  edge [
    fontname = "Roboto"
    fontsize = 8
  ]

